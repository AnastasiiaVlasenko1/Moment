# Copy this file to `.env` and fill in your own Supabase project values.
# Find these in the Supabase dashboard: Project Settings → API.
# Both values below are the PUBLIC/publishable ones — safe to expose in the
# browser bundle. Never add a service_role / secret key to a VITE_ variable;
# anything prefixed VITE_ is shipped to the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
